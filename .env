NODE_ENV="development"
PORT=3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maha_admissions?schema=public"

GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

JWT_ACCESS_SECRET="replace-with-32-char-min-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-32-char-min-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
